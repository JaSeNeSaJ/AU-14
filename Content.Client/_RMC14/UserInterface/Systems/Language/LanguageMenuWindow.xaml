<widgets:LanguageMenuWindow xmlns="https://spacestation14.io"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:widgets="clr-namespace:Content.Client._RMC14.UserInterface.Systems.Language"
                            xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                            Title="{Loc 'language-menu-title'}"
                            MinSize="220 300"
                            SetSize="320 420">

    <PanelContainer Name="MainContainer" HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer Name="ContentContainer" HorizontalExpand="True" VerticalExpand="True" Margin="0">
            <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">

                <LineEdit Name="SearchBar"
                          PlaceHolder="Search..."
                          HorizontalExpand="True"
                          Margin="4 4 4 2"/>

                <BoxContainer Orientation="Horizontal" SeparationOverride="2" Margin="4 0 4 2">
                    <Button Name="FilterAll"      Text="All"  HorizontalExpand="True" ToggleMode="True" Pressed="True"/>
                    <Button Name="FilterFavorites" Text="★"   MinWidth="34" ToggleMode="True" ToolTip="Favorites"/>
                    <Button Name="FilterRecent"    Text="⏲"   MinWidth="34" ToggleMode="True" ToolTip="Recently used"/>
                </BoxContainer>

                <TabContainer Name="TabContainer"
                              HorizontalExpand="True"
                              VerticalExpand="True"
                              Margin="0">

                    <ScrollContainer Name="KnownLanguagesTab"
                                     HorizontalExpand="True"
                                     VerticalExpand="True"
                                     HScrollEnabled="False"
                                     VScrollEnabled="True">
                        <PanelContainer Name="KnownLanguagesContainer" Margin="0">
                            <BoxContainer Name="KnownLanguageList"
                                          Orientation="Vertical"
                                          SeparationOverride="6"
                                          Margin="0"/>
                        </PanelContainer>
                    </ScrollContainer>

                    <ScrollContainer Name="LearningTab"
                                     HorizontalExpand="True"
                                     VerticalExpand="True"
                                     HScrollEnabled="False"
                                     VScrollEnabled="True"
                                     ReturnMeasure="True">
                        <PanelContainer Name="LearningLanguagesContainer"
                                        Margin="0"
                                        HorizontalExpand="True">
                            <BoxContainer Name="LearningLanguageList"
                                          Orientation="Vertical"
                                          SeparationOverride="8"
                                          Margin="0"
                                          HorizontalExpand="True"/>
                        </PanelContainer>
                    </ScrollContainer>

                </TabContainer>
            </BoxContainer>
        </PanelContainer>
    </PanelContainer>
</widgets:LanguageMenuWindow>